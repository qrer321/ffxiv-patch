<!-- Loose XAML loaded at runtime through XamlReader (no x:Class, no event
     attributes). Named elements are resolved and wired in MainWindow.cs. -->
<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="FFXIV 한글 패치"
    Width="780"
    SizeToContent="Height"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    FontFamily="Malgun Gothic, Segoe UI"
    FontSize="12.5"
    UseLayoutRounding="True"
    TextOptions.TextFormattingMode="Display"
    SnapsToDevicePixels="True">

  <Window.Resources>
    <SolidColorBrush x:Key="WinBg" Color="#0E1016"/>
    <SolidColorBrush x:Key="PanelBg" Color="#151923"/>
    <SolidColorBrush x:Key="Panel2Bg" Color="#1A1F2B"/>
    <SolidColorBrush x:Key="BorderBrushMain" Color="#262C3A"/>
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#1E2430"/>
    <SolidColorBrush x:Key="TextMain" Color="#E8E6E1"/>
    <SolidColorBrush x:Key="TextDim" Color="#9AA3B2"/>
    <SolidColorBrush x:Key="TextFaint" Color="#626C7D"/>
    <SolidColorBrush x:Key="Gold" Color="#D4AF6A"/>
    <SolidColorBrush x:Key="GoldBright" Color="#E8C886"/>
    <SolidColorBrush x:Key="Blue" Color="#6AA7D4"/>
    <SolidColorBrush x:Key="Red" Color="#D4746A"/>
    <SolidColorBrush x:Key="Green" Color="#7EC98F"/>
    <SolidColorBrush x:Key="Amber" Color="#E0B85C"/>

    <!-- Card container -->
    <Style x:Key="Card" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource PanelBg}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="16,13"/>
    </Style>

    <!-- Small utility button -->
    <Style x:Key="SubButton" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Padding" Value="13,6"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{StaticResource Panel2Bg}" BorderBrush="{StaticResource BorderBrushMain}"
                    BorderThickness="1" CornerRadius="7" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Gold}"/>
                <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#12161F"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.4"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Title bar window buttons -->
    <Style x:Key="WinButton" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource TextFaint}"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="5" Padding="11,4">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Panel2Bg}"/>
                <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Main action card button: Content = title, Tag = description -->
    <Style x:Key="ActionButton" TargetType="Button">
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Background" Value="{StaticResource PanelBg}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMain}"/>
      <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Grid>
              <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="1" CornerRadius="10" Padding="15,13,15,12">
                <StackPanel>
                  <TextBlock Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                             FontSize="14.5" FontWeight="Bold" Foreground="{TemplateBinding Foreground}"/>
                  <TextBlock Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                             FontSize="11.5" Foreground="{StaticResource TextDim}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
              </Border>
              <Border x:Name="Hover" Background="#0FFFFFFF" CornerRadius="10" Visibility="Collapsed"/>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Hover" Property="Visibility" Value="Visible"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Hover" Property="Background" Value="#1A000000"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.38"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Pill toggle chip -->
    <Style x:Key="Chip" TargetType="ToggleButton">
      <Setter Property="Foreground" Value="{StaticResource TextFaint}"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border x:Name="Bd" Background="Transparent" BorderBrush="{StaticResource BorderBrushMain}"
                    BorderThickness="1" CornerRadius="14" Padding="13,5">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#24D4AF6A"/>
                <Setter TargetName="Bd" Property="BorderBrush" Value="#73D4AF6A"/>
                <Setter Property="Foreground" Value="{StaticResource GoldBright}"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Gold}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.4"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Text-styled expander toggle -->
    <Style x:Key="TextToggle" TargetType="ToggleButton">
      <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border Background="Transparent" Padding="2">
              <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="Arrow" Text="▸" Foreground="{StaticResource TextFaint}" Margin="0,0,7,0"/>
                <ContentPresenter VerticalAlignment="Center"/>
              </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Arrow" Property="Text" Value="▾"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Dark ComboBox -->
    <Style x:Key="DarkComboItem" TargetType="ComboBoxItem">
      <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBoxItem">
            <Border x:Name="Bd" Background="Transparent" Padding="11,7" CornerRadius="6" Margin="3,1">
              <ContentPresenter/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#24D4AF6A"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="DarkCombo" TargetType="ComboBox">
      <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
      <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboItem}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBox">
            <Grid>
              <ToggleButton x:Name="Toggle" Focusable="False" ClickMode="Press"
                            IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                <ToggleButton.Template>
                  <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bd" Background="{StaticResource Panel2Bg}" BorderBrush="{StaticResource BorderBrushMain}"
                            BorderThickness="1" CornerRadius="7">
                      <TextBlock Text="▾" Foreground="{StaticResource TextFaint}" HorizontalAlignment="Right"
                                 VerticalAlignment="Center" Margin="0,0,10,0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Gold}"/>
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </ToggleButton.Template>
              </ToggleButton>
              <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                Margin="11,0,26,0" VerticalAlignment="Center" IsHitTestVisible="False"
                                TextElement.Foreground="{StaticResource TextMain}"/>
              <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                     AllowsTransparency="True" StaysOpen="False" VerticalOffset="4">
                <Border Background="#161B26" BorderBrush="{StaticResource BorderBrushMain}" BorderThickness="1"
                        CornerRadius="8" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="240" Padding="0,3">
                  <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsPresenter/>
                  </ScrollViewer>
                </Border>
              </Popup>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.4"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Slim dark scrollbar for in-card scroll areas -->
    <Style TargetType="ScrollBar">
      <Setter Property="Width" Value="8"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ScrollBar">
            <Grid Background="Transparent">
              <Track x:Name="PART_Track" IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                  <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                  <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                  <Thumb>
                    <Thumb.Template>
                      <ControlTemplate TargetType="Thumb">
                        <Border Background="#3A4356" CornerRadius="4" Margin="1"/>
                      </ControlTemplate>
                    </Thumb.Template>
                  </Thumb>
                </Track.Thumb>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Preflight checklist row -->
    <DataTemplate x:Key="PreflightItemTemplate">
      <Border Background="{StaticResource Panel2Bg}" CornerRadius="6" Padding="10,6" Margin="0,3,0,0">
        <DockPanel>
          <TextBlock DockPanel.Dock="Left" Text="{Binding Icon}" Foreground="{Binding IconBrush}"
                     FontWeight="Bold" Width="22" VerticalAlignment="Top"/>
          <TextBlock Text="{Binding Text}" Foreground="#C9D0DB" TextWrapping="Wrap" FontSize="12"/>
        </DockPanel>
      </Border>
    </DataTemplate>
  </Window.Resources>

  <Border CornerRadius="12" Background="{StaticResource WinBg}" BorderBrush="{StaticResource BorderBrushMain}" BorderThickness="1">
    <DockPanel>

      <!-- ═══ Title bar ═══ -->
      <Border x:Name="TitleBar" DockPanel.Dock="Top" Background="#0A0C11" CornerRadius="11,11,0,0"
              BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="14,9">
        <DockPanel>
          <Border Width="19" Height="19" CornerRadius="4" VerticalAlignment="Center">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E8C886" Offset="0"/>
                <GradientStop Color="#8A6D3A" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
            <TextBlock Text="✦" Foreground="#0E1016" FontSize="11" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
          </Border>
          <TextBlock Text="FFXIV 한글 패치" Foreground="{StaticResource TextMain}" FontWeight="SemiBold"
                     FontSize="12.5" VerticalAlignment="Center" Margin="10,0,0,0"/>
          <Border x:Name="ModeBadge" Visibility="Collapsed" Background="#26E0B85C" BorderBrush="#59E0B85C"
                  BorderThickness="1" CornerRadius="9" Padding="8,1" Margin="10,0,0,0" VerticalAlignment="Center">
            <TextBlock x:Name="ModeBadgeText" Text="TEST BUILD" Foreground="{StaticResource Amber}" FontSize="10"/>
          </Border>
          <Button x:Name="CloseButton" DockPanel.Dock="Right" Style="{StaticResource WinButton}" Content="✕"/>
          <Button x:Name="MinButton" DockPanel.Dock="Right" Style="{StaticResource WinButton}" Content="─" Margin="0,0,2,0"/>
          <Border/>
        </DockPanel>
      </Border>

      <!-- ═══ Footer: status + progress ═══ -->
      <StackPanel DockPanel.Dock="Bottom" Margin="22,4,22,16">
        <DockPanel Margin="0,0,0,7">
          <TextBlock x:Name="FooterPercent" DockPanel.Dock="Right" Foreground="{StaticResource TextDim}"
                     FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0"/>
          <Button x:Name="OpenLastLogButton" DockPanel.Dock="Right" Style="{StaticResource SubButton}"
                  Padding="9,2" FontSize="11" Content="로그 보기" VerticalAlignment="Center"/>
          <TextBlock x:Name="FooterStatus" Foreground="{StaticResource TextDim}" FontSize="12"
                     VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,10,0"/>
        </DockPanel>
        <Border x:Name="ProgressTrack" Height="6" CornerRadius="3" Background="{StaticResource Panel2Bg}" ClipToBounds="True">
          <Border x:Name="ProgressFill" Width="0" Height="6" CornerRadius="3" HorizontalAlignment="Left">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#A8853F" Offset="0"/>
                <GradientStop Color="#E8C886" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
            <Border.RenderTransform>
              <TranslateTransform x:Name="ProgressMarqueeTransform" X="0"/>
            </Border.RenderTransform>
          </Border>
        </Border>
      </StackPanel>

      <!-- ═══ Content ═══ -->
      <StackPanel>

        <!-- Banner -->
        <Grid Height="108" ClipToBounds="True">
          <Image x:Name="BannerImage" Stretch="UniformToFill" VerticalAlignment="Center"/>
          <Rectangle>
            <Rectangle.Fill>
              <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#260E1016" Offset="0"/>
                <GradientStop Color="#8C0E1016" Offset="0.6"/>
                <GradientStop Color="#FF0E1016" Offset="1"/>
              </LinearGradientBrush>
            </Rectangle.Fill>
          </Rectangle>
        </Grid>

        <StackPanel Margin="22,4,22,6">

          <!-- ── 상태 + 설정 카드 ── -->
          <Border Style="{StaticResource Card}">
            <StackPanel>
              <DockPanel Margin="0,0,0,11">
                <Ellipse x:Name="StateDot" Width="9" Height="9" Fill="{StaticResource TextFaint}" VerticalAlignment="Center"/>
                <TextBlock x:Name="StateText" Text="상태 확인 중..." Foreground="{StaticResource TextMain}"
                           FontSize="13.5" FontWeight="Bold" Margin="9,0,0,0" VerticalAlignment="Center"/>
                <Border x:Name="StateBadge" Visibility="Collapsed" Background="{StaticResource Panel2Bg}"
                        BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="9"
                        Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                  <TextBlock x:Name="StateBadgeText" Foreground="{StaticResource TextDim}" FontSize="10.5"/>
                </Border>
                <Border/>
              </DockPanel>

              <Grid Margin="0,0,0,7">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="112"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="글로벌 클라이언트" Foreground="{StaticResource TextDim}" FontSize="12" VerticalAlignment="Center"/>
                <Border Grid.Column="1" Background="{StaticResource Panel2Bg}" BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1" CornerRadius="7" Padding="10,6" Margin="0,0,9,0">
                  <TextBlock x:Name="GlobalPathText" Text="(미설정)" Foreground="{StaticResource TextMain}"
                             FontFamily="Cascadia Code, Consolas" FontSize="11.5" TextTrimming="CharacterEllipsis"/>
                </Border>
                <Button x:Name="GlobalBrowseButton" Grid.Column="2" Style="{StaticResource SubButton}" Content="변경"/>
              </Grid>

              <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="112"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="한국 클라이언트" Foreground="{StaticResource TextDim}" FontSize="12" VerticalAlignment="Center"/>
                <Border Grid.Column="1" Background="{StaticResource Panel2Bg}" BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1" CornerRadius="7" Padding="10,6" Margin="0,0,9,0">
                  <TextBlock x:Name="KoreaPathText" Text="(미설정)" Foreground="{StaticResource TextMain}"
                             FontFamily="Cascadia Code, Consolas" FontSize="11.5" TextTrimming="CharacterEllipsis"/>
                </Border>
                <Button x:Name="KoreaBrowseButton" Grid.Column="2" Style="{StaticResource SubButton}" Content="변경"/>
              </Grid>

              <DockPanel Margin="0,0,0,10">
                <TextBlock Text="베이스 언어" Foreground="{StaticResource TextDim}" FontSize="12"
                           Width="112" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal">
                  <ComboBox x:Name="LanguageCombo" Style="{StaticResource DarkCombo}" Width="190" Height="30"/>
                  <Button x:Name="DetectButton" Style="{StaticResource SubButton}" Content="자동 탐색" Margin="9,0,0,0"/>
                  <Button x:Name="ResetButton" Style="{StaticResource SubButton}" Content="리셋" Margin="7,0,0,0"/>
                </StackPanel>
              </DockPanel>

              <DockPanel>
                <TextBlock Text="원문 유지" Foreground="{StaticResource TextDim}" FontSize="12"
                           Width="112" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal">
                  <ToggleButton x:Name="ChipBnpc" Style="{StaticResource Chip}" Content="보스명"/>
                  <ToggleButton x:Name="ChipAction" Style="{StaticResource Chip}" Content="기술명" Margin="6,0,0,0"/>
                  <ToggleButton x:Name="ChipCommon" Style="{StaticResource Chip}" Content="상용구" Margin="6,0,0,0"/>
                  <TextBlock Text="체크하면 해당 텍스트는 번역하지 않고 원문을 유지합니다" Foreground="{StaticResource TextFaint}"
                             FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>
              </DockPanel>
            </StackPanel>
          </Border>

          <!-- ── 메인 액션 ── -->
          <Grid x:Name="ActionsGrid" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.25*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="FullPatchButton" Style="{StaticResource ActionButton}"
                    Content="전체 한글 패치" Tag="UI · 대사 · 폰트 전체를 한국어로 교체합니다"
                    Foreground="{StaticResource GoldBright}" BorderBrush="#80D4AF6A">
              <Button.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                  <GradientStop Color="#29D4AF6A" Offset="0"/>
                  <GradientStop Color="#0DD4AF6A" Offset="1"/>
                </LinearGradientBrush>
              </Button.Background>
            </Button>
            <Button x:Name="FontPatchButton" Grid.Column="1" Style="{StaticResource ActionButton}" Margin="11,0,0,0"
                    Content="폰트만 패치" Tag="텍스트는 그대로, 채팅의 한글만 표시"
                    Foreground="{StaticResource Blue}" BorderBrush="#596AA7D4">
              <Button.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                  <GradientStop Color="#1A6AA7D4" Offset="0"/>
                  <GradientStop Color="#000E1016" Offset="1"/>
                </LinearGradientBrush>
              </Button.Background>
            </Button>
            <Button x:Name="RemoveButton" Grid.Column="2" Style="{StaticResource ActionButton}" Margin="11,0,0,0"
                    Content="패치 제거" Tag="게임 파일을 원본으로 복원"
                    Foreground="{StaticResource Red}" BorderBrush="#4DD4746A" Background="{StaticResource PanelBg}"/>
          </Grid>

          <!-- 테스트 빌드 전용 액션 -->
          <Button x:Name="TestPatchButton" Style="{StaticResource ActionButton}" Margin="0,12,0,0" Visibility="Collapsed"
                  Content="테스트 자동 패치 (원본 변경 없음)" Tag="실제 클라이언트를 건드리지 않고 debug-apply 폴더에 생성/적용합니다"
                  Foreground="{StaticResource Green}" BorderBrush="#4D7EC98F" Background="{StaticResource PanelBg}"/>

          <!-- 잠금 사유 -->
          <Border x:Name="GuardNote" Visibility="Collapsed" Background="#14E0B85C" BorderBrush="#40E0B85C"
                  BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,10,0,0">
            <DockPanel>
              <TextBlock Text="⚠" Foreground="{StaticResource Amber}" FontSize="12.5" Margin="0,0,9,0" VerticalAlignment="Top"/>
              <TextBlock x:Name="GuardNoteText" Foreground="{StaticResource Amber}" FontSize="12" TextWrapping="Wrap"/>
            </DockPanel>
          </Border>

          <!-- ── 사전 점검 카드 ── -->
          <Border Style="{StaticResource Card}" Margin="0,12,0,0" Padding="16,11">
            <StackPanel>
              <DockPanel>
                <TextBlock x:Name="PreflightIcon" Text="●" Foreground="{StaticResource TextFaint}" FontWeight="Bold"
                           Width="20" VerticalAlignment="Center"/>
                <Button x:Name="PreflightRunButton" DockPanel.Dock="Right" Style="{StaticResource SubButton}"
                        Padding="10,4" FontSize="11.5" Content="다시 점검"/>
                <ToggleButton x:Name="PreflightToggle" DockPanel.Dock="Right" Style="{StaticResource TextToggle}"
                              Content="자세히" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="PreflightSummary" Text="사전 점검 대기 중" Foreground="{StaticResource TextMain}"
                           FontSize="12.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
              </DockPanel>
              <StackPanel x:Name="PreflightPanel" Visibility="Collapsed" Margin="0,9,0,0">
                <ScrollViewer MaxHeight="250" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                  <ItemsControl x:Name="PreflightList" ItemTemplate="{StaticResource PreflightItemTemplate}" Margin="0,0,4,0"/>
                </ScrollViewer>
                <DockPanel Margin="2,8,0,0">
                  <Button x:Name="PreflightLogButton" DockPanel.Dock="Right" Style="{StaticResource SubButton}"
                          Padding="9,3" FontSize="11" Content="로그 열기"/>
                  <ToggleButton x:Name="PreflightShowAllToggle" DockPanel.Dock="Left" Style="{StaticResource TextToggle}"
                                Content="전체 항목 보기" FontSize="11.5" VerticalAlignment="Center" Margin="0,0,12,0"/>
                  <TextBlock x:Name="PreflightLogPath" Foreground="{StaticResource TextFaint}" FontSize="11"
                             VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,10,0"/>
                </DockPanel>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- ── 고급 카드 ── -->
          <Border Style="{StaticResource Card}" Margin="0,12,0,0" Padding="16,11">
            <StackPanel>
              <ToggleButton x:Name="AdvancedToggle" Style="{StaticResource TextToggle}"
                            Content="고급 기능 — 백업 복구 · 폴더 · 정리"/>
              <StackPanel x:Name="AdvancedPanel" Visibility="Collapsed" Margin="0,10,0,2">
                <WrapPanel>
                  <Button x:Name="RestoreBackupButton" Style="{StaticResource SubButton}" Content="백업으로 복구" Margin="0,0,8,8"/>
                  <Button x:Name="OpenReleaseButton" Style="{StaticResource SubButton}" Content="생성 폴더 열기" Margin="0,0,8,8"/>
                  <Button x:Name="OpenLogsButton" Style="{StaticResource SubButton}" Content="로그 폴더 열기" Margin="0,0,8,8"/>
                  <Button x:Name="CleanupButton" Style="{StaticResource SubButton}" Content="오래된 파일 정리" Margin="0,0,8,8"/>
                </WrapPanel>
                <DockPanel x:Name="FontProfileRow" Visibility="Collapsed" Margin="0,2,0,0">
                  <TextBlock Text="테스트 폰트 프로필" Foreground="{StaticResource TextDim}" FontSize="12"
                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                  <ComboBox x:Name="FontProfileCombo" Style="{StaticResource DarkCombo}" Width="210" Height="30"
                            HorizontalAlignment="Left"/>
                </DockPanel>
              </StackPanel>
            </StackPanel>
          </Border>

        </StackPanel>
      </StackPanel>
    </DockPanel>
  </Border>
</Window>
