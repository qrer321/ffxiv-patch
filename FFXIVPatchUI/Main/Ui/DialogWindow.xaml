<!-- Generic dark dialog shell loaded via XamlReader. MainWindow.cs shows or
     hides the optional sections (details table, list box, log row) per use. -->
<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="620"
    SizeToContent="Height"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    FontFamily="Malgun Gothic, Segoe UI"
    FontSize="12.5"
    UseLayoutRounding="True"
    TextOptions.TextFormattingMode="Display"
    ShowInTaskbar="False">

  <Window.Resources>
    <SolidColorBrush x:Key="WinBg" Color="#11141B"/>
    <SolidColorBrush x:Key="Panel2Bg" Color="#1A1F2B"/>
    <SolidColorBrush x:Key="BorderBrushMain" Color="#2A3140"/>
    <SolidColorBrush x:Key="TextMain" Color="#E8E6E1"/>
    <SolidColorBrush x:Key="TextDim" Color="#9AA3B2"/>
    <SolidColorBrush x:Key="TextFaint" Color="#626C7D"/>
    <SolidColorBrush x:Key="Gold" Color="#D4AF6A"/>

    <Style x:Key="DlgButton" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="MinWidth" Value="96"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{StaticResource Panel2Bg}" BorderBrush="{StaticResource BorderBrushMain}"
                    BorderThickness="1" CornerRadius="7" Padding="16,7">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Gold}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#12161F"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="DlgPrimaryButton" TargetType="Button" BasedOn="{StaticResource DlgButton}">
      <Setter Property="Foreground" Value="#0E1016"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" BorderThickness="1" CornerRadius="7" Padding="16,7" BorderBrush="#E8C886">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                  <GradientStop Color="#E0BC77" Offset="0"/>
                  <GradientStop Color="#C29A52" Offset="1"/>
                </LinearGradientBrush>
              </Border.Background>
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <DataTemplate x:Key="DetailItemTemplate">
      <Border Background="{StaticResource Panel2Bg}" CornerRadius="6" Padding="10,6" Margin="0,3,0,0">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <TextBlock Text="{Binding Key}" Foreground="{StaticResource TextDim}" FontSize="12" VerticalAlignment="Top"/>
          <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="#D8DEE8" FontSize="12" TextWrapping="Wrap"/>
        </Grid>
      </Border>
    </DataTemplate>

    <Style x:Key="DlgListItem" TargetType="ListBoxItem">
      <Setter Property="Foreground" Value="#C9D0DB"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Padding="10,7" Margin="0,1">
              <ContentPresenter/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#24D4AF6A"/>
                <Setter Property="Foreground" Value="#E8C886"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Gold}"/>
                <Setter TargetName="Bd" Property="BorderThickness" Value="0"/>
                <Setter TargetName="Bd" Property="Background" Value="#141A26"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Border CornerRadius="12" Background="{StaticResource WinBg}" BorderBrush="{StaticResource BorderBrushMain}" BorderThickness="1">
    <DockPanel>
      <!-- Header (drag area) -->
      <Border x:Name="DialogHeader" DockPanel.Dock="Top" Background="#0A0C11" CornerRadius="11,11,0,0"
              BorderBrush="#1E2430" BorderThickness="0,0,0,1" Padding="16,10">
        <DockPanel>
          <Rectangle x:Name="AccentBar" Width="4" Height="16" RadiusX="2" RadiusY="2"
                     Fill="{StaticResource Gold}" VerticalAlignment="Center"/>
          <TextBlock x:Name="DialogTitle" Text="알림" Foreground="{StaticResource TextMain}" FontWeight="SemiBold"
                     FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
          <Border/>
        </DockPanel>
      </Border>

      <StackPanel Margin="20,16,20,18">
        <TextBlock x:Name="DialogMessage" Foreground="#D8DEE8" FontSize="12.5" TextWrapping="Wrap" LineHeight="20"/>

        <ItemsControl x:Name="DialogDetails" ItemTemplate="{StaticResource DetailItemTemplate}"
                      Visibility="Collapsed" Margin="0,12,0,0"/>

        <ListBox x:Name="DialogList" Visibility="Collapsed" Margin="0,12,0,0" MaxHeight="260"
                 Background="{StaticResource Panel2Bg}" BorderBrush="#242B38" BorderThickness="1"
                 ItemContainerStyle="{StaticResource DlgListItem}" Padding="4"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
          <ListBox.Template>
            <ControlTemplate TargetType="ListBox">
              <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                  <ItemsPresenter/>
                </ScrollViewer>
              </Border>
            </ControlTemplate>
          </ListBox.Template>
        </ListBox>

        <DockPanel x:Name="DialogLogRow" Visibility="Collapsed" Margin="2,12,0,0">
          <Button x:Name="DialogLogButton" DockPanel.Dock="Right" Style="{StaticResource DlgButton}"
                  MinWidth="0" Padding="10,4" FontSize="11.5" Content="로그 열기"/>
          <TextBlock x:Name="DialogLogPath" Foreground="{StaticResource TextFaint}" FontSize="11"
                     VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,10,0"/>
        </DockPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
          <Button x:Name="DialogSecondaryButton" Style="{StaticResource DlgButton}" Content="취소"
                  Visibility="Collapsed" Margin="0,0,9,0"/>
          <Button x:Name="DialogPrimaryButton" Style="{StaticResource DlgPrimaryButton}" Content="확인"/>
        </StackPanel>
      </StackPanel>
    </DockPanel>
  </Border>
</Window>
